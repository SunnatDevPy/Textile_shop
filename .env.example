# Nusxa: cp .env.example .env && nano .env
# Docker Compose: app/bot konteynerlarida DB_HOST va DB_PORT compose orqali ustidan yoziladi (db:5432).

DB_NAME=textile
DB_HOST=db
DB_PORT=5432
DB_PASS=1
DB_USER=postgres
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=60
DB_POOL_RECYCLE=1800

# DEMO super admin — login admin, parol 1111
# Docker Compose: bcrypt hashdagi har bir $ ni $$ bilan yozing, aks holda ADMIN_PASS buziladi (bcrypt Invalid salt).
ADMIN_USERNAME=admin
ADMIN_PASS=$$2b$$12$$pRh6NEqbXYos2pxcbC48muRp7i3uLXr3W6PhUhFIto09txasqjx/y
SECRET_KEY=<random_secret_key>

# To'lovdan keyin redirect (Click return_url, Payme optional)
PUBLIC_BASE_URL=https://textile.okach-admin.uz

# Payment
CLICK_SECRET_KEY=
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_MERCHANT_USER_ID=
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
PAYME_ENDPOINT=https://checkout.test.paycom.uz
PAYMENT_CALLBACK_IP_WHITELIST=
RATE_LIMIT_PER_MINUTE=120

SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

TG_BOT_TOKEN=
TG_GROUP_IDS=
TG_WEBHOOK_URL=
TG_WEBHOOK_SECRET=
